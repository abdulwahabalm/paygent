  "bugs": {
    "url": "https://github.com/abdulwahabalm/paygent/issues"
  },
  "homepage": "https://github.com/abdulwahabalm/paygent#readme",
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^2.1.0",
    "@mozilla/readability": "^0.6.0",
    "@stellar/stellar-sdk": "^15.0.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "jsdom": "^29.0.2",
    "multer": "^2.1.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.14"
