{
  "name": "paygent",
  "version": "1.0.0",
  "description": "An autonomous API gateway where every query has a price (pay XLM, get answers).",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "devStart": "nodemon server.js",
